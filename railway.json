{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",

    "buildCommand": "cd austin-ossf-tool/apps/web && npm install && npm run build"
      },
  "deploy": {
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 5,
"startCommand": "cd austin-ossf-tool/apps/web && npm run start"  }
}
